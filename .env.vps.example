# Copie no VPS:  cp .env.vps.example .env
# Guia: docs/DEPLOY_VPS.md

# Assistente IA (opcional)
DEEPSEEK_API_KEY=

# IP Tailscale ou LAN do VPS — Kafka em :9092 para clientes fora do Docker
KAFKA_EXTERNAL_HOST=

# RabbitMQ + SMTP (alerta de fraude por e-mail)
RABBITMQ_USER=datamaster
RABBITMQ_PASSWORD=datamaster
FRAUD_EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
FRAUD_ALERT_TO=
