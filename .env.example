# Copie para .env na raiz:  cp .env.example .env
# Guia: docs/AMBIENTE_LOCAL.md | docs/FRAUD_EMAIL_RABBITMQ.md

# Assistente no painel (chat via API Java → DeepSeek) — opcional
DEEPSEEK_API_KEY=

# Mac: caminho ABSOLUTO do repo (console :3333 → spark-job via Docker socket)
# DOCKER_HOST_WORKSPACE=/Users/seu.usuario/projetos/datamaster

# --- RabbitMQ (alerta de fraude assíncrono) ---
RABBITMQ_USER=datamaster
RABBITMQ_PASSWORD=datamaster
FRAUD_EMAIL_ENABLED=true

# --- SMTP (consumidor email-worker) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
SMTP_FROM=seu-email@gmail.com
SMTP_STARTTLS=true
FRAUD_ALERT_TO=destino@example.com
